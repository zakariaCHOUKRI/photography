---
import BaseLayout from '../components/BaseLayout.astro';
import GalleryCard from '../components/GalleryCard.astro';
import GalleryGrid from '../components/GalleryGrid.astro';
import { galleries } from '../data/galleries';

const BASE = import.meta.env.BASE_URL || '/';
const basePath = BASE.endsWith('/') ? BASE : `${BASE}/`;
const image = (path: string) => `${basePath}${path.replace(/^\//, '')}`;

const featuredGalleries = galleries.filter((gallery) => gallery.featured).slice(0, 3);
const heroImage = image('images/other/jumping_in_water.jpg');
const allPhotos = galleries.flatMap((gallery) => gallery.photos);
const glimpsesPhotos = allPhotos.slice(0, 4);
---

<BaseLayout
  title="Zakaria Choukri Photography"
  description="Editorial, minimal photography portfolio featuring selected galleries by Zakaria Choukri."
>
  <section class="hero">
    <img
      src={heroImage}
      alt="Featured photograph"
      width="1600"
      height="1067"
      loading="eager"
      decoding="async"
      fetchpriority="high"
    />
  </section>

  <section class="stack" aria-labelledby="featured-galleries">
    <h2 id="featured-galleries">Featured Galleries</h2>
    <ul class="gallery-list" role="list">
      {featuredGalleries.map((gallery) => (
        <li><GalleryCard gallery={gallery} /></li>
      ))}
    </ul>
  </section>

  <section class="stack" aria-labelledby="glimpses">
    <h2 id="glimpses">Glimpses</h2>
    <GalleryGrid photos={glimpsesPhotos} heading="Glimpses" />
    <div id="__all_photos" data-json={JSON.stringify(allPhotos)} hidden></div>
    <script type="text/javascript">
      (function () {

        function pickRandom(array, n) {
          const arr = array.slice();
          for (let i = arr.length - 1; i > 0; i--) {
            const j = Math.floor(Math.random() * (i + 1));
            [arr[i], arr[j]] = [arr[j], arr[i]];
          }
          return arr.slice(0, n);
        }

        function hydrateGlimpses() {
          let allPhotos = [];
          try {
            const el = document.getElementById('__all_photos');
            allPhotos = el ? JSON.parse(el.dataset.json || '[]') : [];
          } catch (e) {
            return;
          }
          const picks = pickRandom(allPhotos, 4);
          const grid = document.querySelector('.gallery-grid');
          if (!grid) return;
          const items = grid.querySelectorAll('li');
          items.forEach((li, idx) => {
            const photo = picks[idx];
            if (!photo) return;
            const img = li.querySelector('img');
            const link = li.querySelector('a.photo-card-link');
            const titleEl = li.querySelector('.photo-title');
            const detailsEl = li.querySelector('.photo-details');
            if (img) {
              img.src = photo.thumb || photo.src;
              img.alt = photo.alt || '';
            }
            if (link) link.href = photo.src;
            if (titleEl) titleEl.textContent = photo.title || '';
            if (detailsEl) {
              const loc = photo.location || '';
              const year = photo.year || '';
              detailsEl.textContent = loc + (loc && year ? ' · ' : '') + year;
            }
          });
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', hydrateGlimpses);
        } else {
          hydrateGlimpses();
        }
      })();
    </script>
  </section>

</BaseLayout>
