---
interface Props {
  src: string;
  thumb?: string;
  alt: string;
  title?: string;
  location?: string;
  year?: number;
}

const {
  src,
  thumb,
  alt,
  title,
  location,
  year
} = Astro.props;

const imageSrc = thumb ?? src;
---

<article class="photo-card">
  <div class="photo-frame">
    <a href={src} class="photo-card-link">
      <img
        src={imageSrc}
        alt={alt}
        loading="lazy"
        decoding="async"
      />
    </a>
  </div>
  {(title || location || year) && (
    <div class="photo-meta">
      {title && <p class="photo-title">{title}</p>}
      {(location || year) && (
        <p class="photo-details">
          {location}{location && year ? ' · ' : ''}{year}
        </p>
      )}
    </div>
  )}
</article>

<style>
  .photo-card {
    padding: 1rem;
  }

  .photo-frame {
    width: min(100%, 72rem);
    height: min(80vh, 48rem);
    margin: 0 auto;
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    background: var(--surface);
  }

  .photo-card-link {
    display: flex;
    width: 100%;
    height: 100%;
    align-items: center;
    justify-content: center;
  }

  .photo-card img {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
  }
</style>
